{
  "name": "claude-telegram-relay",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/relay.ts",
    "dev": "bun run --watch src/relay.ts",
    "setup": "bun run setup/install.ts",
    "test:telegram": "bun run setup/test-telegram.ts",
    "test:supabase": "bun run setup/test-supabase.ts",
    "test:voice": "bun run setup/test-voice.ts",
    "test:websearch": "bun run setup/test-websearch.ts",
    "test:pdf": "bun run setup/test-pdf.ts",
    "setup:launchd": "bun run setup/configure-launchd.ts",
    "setup:services": "bun run setup/configure-services.ts",
    "setup:verify": "bun run setup/verify.ts",
    "status": "bun run scripts/status.ts",
    "status:reset": "bun run scripts/status.ts --reset",
    "status:json": "bun run scripts/status.ts --json",
    "example:status": "bun run examples/status-example.ts",
    "example:terminal-status": "bun run examples/terminal-status-demo.ts",
    "test:status": "bun run examples/quick-status-test.ts",
    "watch:status": "./watch-status.sh",
    "monitor:context": "./monitor-context.sh",
    "setup:tmux-statusbar": "./setup-tmux-statusbar.sh",
    "setup:prompt-context": "./setup-prompt-context.sh",
    "setup:simple-prompt": "./setup-simple-prompt.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "grammy": "^1.21.1",
    "groq-sdk": "^0.8.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "2.16.105"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
