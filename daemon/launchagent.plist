<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Unique identifier for this service -->
    <key>Label</key>
    <string>com.claude.telegram-relay</string>

    <!-- Command to run -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/german/.bun/bin/bun</string>
        <string>run</string>
        <string>src/relay.ts</string>
    </array>

    <!-- Working directory -->
    <key>WorkingDirectory</key>
    <string>/Users/german/seconbrain/claude-telegram-relay</string>

    <!-- Environment variables -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/german/.bun/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/german</string>
        <!-- Google Workspace CLI credentials for Gmail access -->
        <key>GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE</key>
        <string>/Users/german/seconbrain/claude-telegram-relay/.gws-credentials.json</string>
    </dict>

    <!-- Start when loaded -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Keep running (restart if it crashes) -->
    <key>KeepAlive</key>
    <true/>

    <!-- Log files -->
    <key>StandardOutPath</key>
    <string>/Users/german/Library/Logs/com.claude.telegram-relay.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/german/Library/Logs/com.claude.telegram-relay.error.log</string>

    <!-- Wait 10 seconds before restarting after crash -->
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
